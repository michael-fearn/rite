{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "backend", "deploy"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "hostname": { "type": "string", "minLength": 1 },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vm", "port"],
      "properties": {
        "vm": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "exposure": { "enum": ["lan_only"] },
        "tls": { "enum": ["letsencrypt_dns"] }
      }
    },
    "auth": { "type": "object" },
    "deploy": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type", "containers"],
          "properties": {
            "type": { "const": "quadlet" },
            "network": { "type": "string" },
            "containers": { "type": "array", "minItems": 1, "items": { "type": "object" } }
          },
          "additionalProperties": true
        },
        {
          "type": "object",
          "required": ["type", "package", "service_name"],
          "properties": {
            "type": { "const": "native" },
            "package": { "type": "string", "minLength": 1 },
            "apt_repo": { "type": "string" },
            "service_name": { "type": "string", "minLength": 1 },
            "config_files": { "type": "array", "items": { "type": "object" } },
            "env_files": { "type": "array", "items": { "type": "object" } }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
