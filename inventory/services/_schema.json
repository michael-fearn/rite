{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "access": { "enum": ["read_only", "read_write"] },
    "container_path": { "type": "string", "pattern": "^/" },
    "service_path": {
      "type": "string",
      "minLength": 1,
      "not": { "pattern": "(^/|(^|/)\\.\\.($|/))" }
    },
    "share_source": {
      "type": "string",
      "minLength": 1,
      "anyOf": [
        { "const": "/" },
        { "not": { "pattern": "(^/|(^|/)\\.\\.($|/))" } }
      ]
    },
    "service_owned_volume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service_path", "container"],
      "properties": {
        "service_path": { "$ref": "#/$defs/service_path" },
        "container": { "$ref": "#/$defs/container_path" },
        "access": { "$ref": "#/$defs/access" }
      }
    },
    "share_backed_volume": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mount", "source", "container"],
      "properties": {
        "mount": { "type": "string", "minLength": 1 },
        "source": { "$ref": "#/$defs/share_source" },
        "container": { "$ref": "#/$defs/container_path" },
        "access": { "$ref": "#/$defs/access" }
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "backend", "deploy"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "hostname": { "type": "string", "minLength": 1 },
    "service_group": {
      "description": "Logical Service Group for operator workflows; does not imply shared private networking.",
      "type": "string",
      "minLength": 1
    },
    "service_network": {
      "description": "VM-local Service Network for shared private Podman networking and Container Alias resolution.",
      "type": "string",
      "minLength": 1
    },
    "service_data_owner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["uid", "gid"],
      "properties": {
        "uid": { "type": "integer", "minimum": 0 },
        "gid": { "type": "integer", "minimum": 0 }
      }
    },
    "dns": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "provider": { "enum": ["pihole"] },
        "ingress_records": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled"],
          "properties": {
            "enabled": { "type": "boolean" }
          }
        }
      }
    },
    "backend": {
      "type": "object",
      "additionalProperties": false,
      "required": ["vm", "port"],
      "properties": {
        "vm": { "type": "string", "minLength": 1 },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "exposure": { "enum": ["lan_only"] },
        "tls": { "enum": ["letsencrypt_dns"] },
        "auth": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "enum": ["none"] }
          }
        }
      }
    },
    "instrumentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["telemetry_targets"],
      "properties": {
        "telemetry_targets": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "type", "published_port"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "type": { "enum": ["prometheus_metrics", "http_probe"] },
              "published_port": { "type": "integer", "minimum": 1, "maximum": 65535 },
              "scheme": { "enum": ["http", "https"] },
              "path": { "type": "string", "pattern": "^/" }
            }
          }
        }
      }
    },
    "deploy": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "containers"],
          "properties": {
            "type": { "const": "quadlet" },
            "containers": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["name", "image"],
                "properties": {
                  "name": { "type": "string", "minLength": 1 },
                  "image": { "type": "string", "minLength": 1 },
                  "published_ports": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["container"],
                      "properties": {
                        "container": { "type": "integer", "minimum": 1, "maximum": 65535 },
                        "host": { "type": "integer", "minimum": 1, "maximum": 65535 },
                        "bind": { "type": "string", "minLength": 1 },
                        "protocol": { "enum": ["tcp", "udp", "tcp_udp"] },
                        "ingress": { "type": "boolean" }
                      }
                    }
                  },
                  "volumes": {
                    "type": "array",
                    "items": {
                      "oneOf": [
                        { "$ref": "#/$defs/service_owned_volume" },
                        { "$ref": "#/$defs/share_backed_volume" }
                      ]
                    }
                  },
                  "env": {
                    "type": "object",
                    "additionalProperties": { "type": ["string", "number", "boolean"] }
                  },
                  "secrets": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["secret", "env"],
                      "properties": {
                        "secret": { "type": "string", "minLength": 1 },
                        "env": { "type": "string", "minLength": 1 },
                        "env_value": { "enum": ["file_path", "secret_name"] }
                      }
                    }
                  },
                  "depends_on": {
                    "type": "array",
                    "items": { "type": "string", "minLength": 1 }
                  }
                }
              }
            }
          }
        },
        {
          "type": "object",
          "required": ["type", "package", "service_name", "config_files"],
          "properties": {
            "type": { "const": "native" },
            "package": { "type": "string", "minLength": 1 },
            "apt_repo": { "type": "string", "minLength": 1 },
            "service_name": { "type": "string", "minLength": 1 },
            "caddy_modules": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["package", "module"],
                "properties": {
                  "package": { "type": "string", "minLength": 1 },
                  "module": { "type": "string", "minLength": 1 }
                }
              }
            },
            "environment_secrets": {
              "type": "array",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["secret", "env"],
                "properties": {
                  "secret": { "type": "string", "minLength": 1 },
                  "env": { "type": "string", "minLength": 1 }
                }
              }
            },
            "config_files": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["template", "dest", "mode"],
                "properties": {
                  "template": {
                    "type": "string",
                    "minLength": 1,
                    "not": { "pattern": "(^/|(^|/)\\.\\.($|/))" }
                  },
                  "dest": { "type": "string", "pattern": "^/" },
                  "mode": { "type": "string", "pattern": "^[0-7]{4}$" },
                  "reload_on_change": { "const": true },
                  "restart_on_change": { "const": true }
                },
                "oneOf": [
                  {
                    "required": ["reload_on_change"],
                    "not": { "required": ["restart_on_change"] }
                  },
                  {
                    "required": ["restart_on_change"],
                    "not": { "required": ["reload_on_change"] }
                  }
                ]
              }
            }
          },
          "additionalProperties": false
        }
      ]
    }
  }
}
