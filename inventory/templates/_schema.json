{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "vmid", "source", "hardware"],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "vmid": { "type": "integer", "minimum": 9000, "maximum": 9999 },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["url", "checksum"],
      "properties": {
        "url": { "type": "string", "format": "uri" },
        "checksum": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "enum": ["sha512"] },
            "value": { "type": "string", "pattern": "^[A-Fa-f0-9]{128}$" }
          }
        }
      }
    },
    "customize": { "type": "object" },
    "hardware": {
      "type": "object",
      "required": ["cores", "memory"],
      "additionalProperties": true,
      "properties": {
        "cores": { "type": "integer", "minimum": 1 },
        "memory": { "type": "integer", "minimum": 256 }
      }
    }
  }
}
