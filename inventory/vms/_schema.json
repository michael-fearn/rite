{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["vmid", "placement", "source", "hardware", "cloud_init"],
  "properties": {
    "vmid": { "type": "integer", "minimum": 100, "maximum": 8999 },
    "description": { "type": "string" },
    "placement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host"],
      "properties": { "host": { "type": "string", "minLength": 1 } }
    },
    "source": {
      "type": "object",
      "additionalProperties": false,
      "required": ["template"],
      "properties": { "template": { "type": "string", "minLength": 1 } }
    },
    "hardware": {
      "type": "object",
      "additionalProperties": false,
      "required": ["cores", "memory"],
      "properties": {
        "cores": { "type": "integer", "minimum": 1 },
        "memory": { "type": "integer", "minimum": 256 },
        "disks": { "type": "array", "items": { "type": "object" } },
        "pci_devices": { "type": "array", "items": { "type": "object" } }
      }
    },
    "network": { "type": "object" },
    "cloud_init": {
      "type": "object",
      "additionalProperties": false,
      "required": ["hostname"],
      "properties": { "hostname": { "type": "string", "minLength": 1 } }
    },
    "nfs_mounts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["export", "mount_point"],
        "properties": {
          "export": { "type": "string", "minLength": 1 },
          "mount_point": { "type": "string", "pattern": "^/" },
          "options_extra": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "backup": { "type": "object" },
    "ssh_public_key": { "type": "string" }
  }
}
