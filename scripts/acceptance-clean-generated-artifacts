#!/usr/bin/env python3
import os
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
sys.path.insert(0, str(REPO_ROOT))

from fortress_acceptance.lifecycle import (  # noqa: E402
    build_generated_artifact_cleanup_plan,
    delete_generated_artifact_cleanup_plan,
    discover_generated_artifacts,
)


WORKFLOWS = {"nfs-shared-mount", "service-layer"}


def main():
    args = parse_args(sys.argv[1:])
    if args is None:
        print(
            "usage: scripts/acceptance-clean-generated-artifacts "
            "workflow=<nfs-shared-mount|service-layer|all> [auto_confirm=<true|false>]",
            file=sys.stderr,
        )
        return 2

    repo_root = Path(os.environ.get("FORTRESS_ROOT", REPO_ROOT))
    workflows = sorted(WORKFLOWS) if args["workflow"] == "all" else [args["workflow"]]
    plan = build_generated_artifact_cleanup_plan(discover_generated_artifacts(repo_root, workflows))
    print_plan(plan)
    has_deletions = any(item["action"] == "delete" for item in plan)
    if has_deletions and not args["auto_confirm"] and not confirm():
        print("generated Acceptance artifact cleanup: cancelled")
        return 1

    errors = delete_generated_artifact_cleanup_plan(plan)
    print_summary(plan)
    for error in errors:
        print(error, file=sys.stderr)
    return 1 if errors else 0


def parse_args(argv):
    values = {}
    for arg in argv:
        if "=" not in arg:
            return None
        key, value = arg.split("=", 1)
        values[key] = value.strip('"')
    if set(values) - {"workflow", "auto_confirm"}:
        return None
    workflow = values.get("workflow")
    if workflow not in WORKFLOWS and workflow != "all":
        return None
    auto_confirm = values.get("auto_confirm", "false").lower()
    if auto_confirm not in ("true", "false"):
        return None
    return {"workflow": workflow, "auto_confirm": auto_confirm == "true"}


def print_plan(plan):
    print("Generated Acceptance artifact cleanup plan")
    for item in plan:
        artifact = item["artifact"]
        print(f"{item['action']}: {artifact.kind}: {artifact.path}")


def confirm():
    try:
        response = input("Type 'clean generated acceptance artifacts' to delete: ")
    except EOFError:
        return False
    return response == "clean generated acceptance artifacts"


def print_summary(plan):
    deleted = sum(1 for item in plan if item["action"] == "delete")
    absent = sum(1 for item in plan if item["action"] == "absent")
    refused = sum(1 for item in plan if item["action"] == "refuse")
    print(f"generated Acceptance artifact cleanup: deleted: {deleted}, absent: {absent}, refused: {refused}")


if __name__ == "__main__":
    raise SystemExit(main())
