#!/usr/bin/env python3
import hashlib
import os
import shlex
import subprocess
import sys
import time
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
FORTRESS_RUNTIME_PYTHON = Path("/opt/fortress-python/bin/python3")
RELOAD_CREDENTIAL_ENV = "FORTRESS_SERVICE_LAYER_ACCEPTANCE_NAS_TOKEN"
sys.path.insert(0, str(REPO_ROOT))

from fortress_acceptance.lifecycle import (  # noqa: E402
    acceptance_artifact_lifecycle,
    build_generated_artifact_cleanup_plan,
    delete_generated_artifact_cleanup_plan,
    phase_detail,
    run,
    ssh_check,
)
from fortress_inventory.model import load_inventory_tree  # noqa: E402


POLICY_NAME = "service-layer"
SERVICE_NAME = "tmp-service-layer"
NATIVE_SERVICE_NAME = "tmp-service-layer-native"
NATIVE_SERVICE_UNIT = "caddy"
NATIVE_SERVICE_MARKER = "native-service-layer-marker"

LIFECYCLE = acceptance_artifact_lifecycle(POLICY_NAME)


def main():
    if sys.argv[1:2] == ["__reload-truenas-nfs-service"]:
        return reload_truenas_nfs_service_child(sys.argv[2:])

    args = parse_args(sys.argv[1:])
    if args is None:
        print(
            "usage: scripts/acceptance-service-layer "
            "host=<host> template=<template> endpoint=<nas-endpoint> "
            "[auto_confirm=<true|false>] [keep_on_fail=<true|false>]",
            file=sys.stderr,
        )
        return 2

    repo_root = Path(os.environ.get("FORTRESS_ROOT", REPO_ROOT))
    early_overwrite_check = LIFECYCLE.refuse_existing_policy_artifacts(repo_root)
    if early_overwrite_check != 0:
        return early_overwrite_check
    early_service_overwrite_check = LIFECYCLE.refuse_existing_registered_artifacts(repo_root)
    if early_service_overwrite_check != 0:
        return early_service_overwrite_check

    inventory = load_inventory_tree(repo_root)
    resolved = LIFECYCLE.resolve_intent(repo_root, inventory, args)
    if isinstance(resolved, int):
        return resolved
    intent = resolved

    overwrite_check = LIFECYCLE.refuse_existing_artifacts(repo_root, intent["vms"])
    if overwrite_check != 0:
        return overwrite_check
    dataset_overwrite_check = LIFECYCLE.refuse_existing_dataset_artifact(repo_root, intent)
    if dataset_overwrite_check != 0:
        return dataset_overwrite_check
    service_overwrite_check = LIFECYCLE.refuse_existing_registered_artifacts(repo_root)
    if service_overwrite_check != 0:
        return service_overwrite_check

    print_intent(intent)
    if not args["auto_confirm"] and not confirm():
        print("service-layer acceptance: cancelled")
        return 1

    generated = False
    provisioned = []
    try:
        progress("generating temporary Inventory artifacts")
        write_generated_inventory(repo_root, intent)
        generated = True
        progress("encrypting generated Service Sibling SOPS File")
        encryption = encrypt_service_sops(repo_root)
        if encryption.returncode != 0:
            return failed_after_generation(repo_root, intent, "Service Sibling SOPS File encryption", encryption, args["keep_on_fail"], generated, provisioned, require_nas_cleanup=False)
        progress(f"reconciling Ephemeral Dataset and Derived NFS Share on NAS Endpoint {intent['endpoint']}")
        reconcile = LIFECYCLE.run_reconcile(repo_root, intent, destroy=False)
        if reconcile.returncode != 0:
            return failed_after_generation(
                repo_root,
                intent,
                "NAS Reconcile",
                reconcile,
                args["keep_on_fail"],
                generated,
                provisioned,
                require_nas_cleanup=False,
            )
        assertion = LIFECYCLE.assert_reconcile_share(reconcile.stdout, intent)
        if assertion:
            return failed_after_generation(repo_root, intent, "NAS Reconcile assertion", assertion, args["keep_on_fail"], generated, provisioned)

        failed_vm, up = LIFECYCLE.provision_vms(
            repo_root,
            intent,
            args["auto_confirm"],
            provisioned,
            progress=lambda vm: progress(f"provisioning {vm['role']} Acceptance VM {vm['name']}"),
        )
        if up.returncode != 0:
            return failed_after_generation(repo_root, intent, f"vm-up {failed_vm['name']}", up, args["keep_on_fail"], generated, provisioned)

        progress(f"deploying generated Service {SERVICE_NAME} to {intent['vms'][0]['name']}")
        service_deploy = run_service_deploy(repo_root, intent)
        if service_deploy.returncode != 0:
            return failed_after_generation(repo_root, intent, "service-deploy", service_deploy, args["keep_on_fail"], generated, provisioned)

        progress(f"deploying generated Native Service {NATIVE_SERVICE_NAME} to {intent['vms'][0]['name']}")
        native_service_deploy = run_native_service_deploy(repo_root, intent)
        if native_service_deploy.returncode != 0:
            return failed_after_generation(repo_root, intent, "native service-deploy", native_service_deploy, args["keep_on_fail"], generated, provisioned)

        progress("verifying Service-layer contract")
        verification = verify_service_layer(repo_root, intent)
        if verification.returncode != 0:
            return failed_after_generation(repo_root, intent, "verification", verification, args["keep_on_fail"], generated, provisioned)

        progress(f"reloading TrueNAS NFS service on NAS Endpoint {intent['endpoint']}")
        reload_result = reload_truenas_nfs_service(repo_root, intent)
        if reload_result.returncode != 0:
            return failed_after_generation(repo_root, intent, "TrueNAS NFS service reload", reload_result, args["keep_on_fail"], generated, provisioned)

        progress("verifying post-reload Mount and Share-backed Volume data flow")
        post_reload = verify_post_reload_data_flow(repo_root, intent)
        if post_reload.returncode != 0:
            return failed_after_generation(repo_root, intent, "post-reload verification", post_reload, args["keep_on_fail"], generated, provisioned)

        progress("cleaning up generated Acceptance resources")
        cleanup = cleanup_resources(repo_root, intent, provisioned)
        if cleanup.returncode != 0:
            print(f"cleanup failed: {phase_detail(cleanup)}", file=sys.stderr)
            return 1
        print("service-layer acceptance: passed")
        return 0
    except OSError as error:
        result = subprocess.CompletedProcess([], 1, "", str(error))
        return failed_after_generation(repo_root, intent, "workflow", result, args["keep_on_fail"], generated, provisioned)


def parse_args(argv):
    values = {}
    for arg in argv:
        if "=" not in arg:
            return None
        key, value = arg.split("=", 1)
        values[key] = value.strip('"')
    if set(values) - {"host", "template", "endpoint", "auto_confirm", "keep_on_fail"}:
        return None
    if not {"host", "template", "endpoint"} <= set(values):
        return None
    for key in ("auto_confirm", "keep_on_fail"):
        values[key] = values.get(key, "false").lower()
        if values[key] not in ("true", "false"):
            return None
        values[key] = values[key] == "true"
    return values


def print_intent(intent):
    print("Service-layer Acceptance Test intent")
    print(f"Host: {intent['host']}")
    print(f"Template: {intent['template']}")
    print(f"NAS Endpoint: {intent['endpoint']}")
    print(f"Dataset: {intent['dataset']['name']}")
    for vm in intent["vms"]:
        print(f"{vm['role']}: {vm['name']} VMID {vm['vmid']} {vm['address']}")


def progress(message):
    print(f"service-layer acceptance: {message}", flush=True)


def confirm():
    response = input("Type 'acceptance service layer' to continue: ")
    return response == "acceptance service layer"


def write_generated_inventory(repo_root, intent):
    LIFECYCLE.write_generated_dataset(repo_root, intent)
    LIFECYCLE.write_generated_vms(repo_root, intent)
    write_service_yaml(repo_root / "inventory" / "services" / f"{SERVICE_NAME}.yaml", intent)
    write_service_sops(repo_root, repo_root / "inventory" / "services" / f"{SERVICE_NAME}.sops.yaml")
    write_service_quadlet_fragment(repo_root / "inventory" / "services" / f"{SERVICE_NAME}.quadlet.d")
    write_native_service_yaml(repo_root / "inventory" / "services" / f"{NATIVE_SERVICE_NAME}.yaml", intent)
    write_native_service_templates(repo_root / "inventory" / "services" / f"{NATIVE_SERVICE_NAME}.native.d")


def write_service_yaml(path, intent):
    mount = intent["policy"]["mount"]
    primary = next(vm for vm in intent["vms"] if vm["role"] == "primary")
    path.write_text(
        f"name: {SERVICE_NAME}\n"
        "generated: true\n"
        "generated_by: service-layer-acceptance\n"
        "service_group: service-layer-acceptance\n"
        "service_data_owner:\n"
        "  uid: 1000\n"
        "  gid: 1000\n"
        "backend:\n"
        f"  vm: {primary['name']}\n"
        "  port: 8080\n"
        "ingress:\n"
        "  enabled: false\n"
        "deploy:\n"
        "  type: quadlet\n"
        "  containers:\n"
        "    - name: web\n"
        "      image: docker.io/library/nginx:1.27\n"
        "      depends_on: [postgres, redis]\n"
        "      published_ports:\n"
        "        - bind: 0.0.0.0\n"
        "          host: 8080\n"
        "          container: 80\n"
        "      volumes:\n"
        "        - service_path: web\n"
        "          container: /srv/fortress-service-layer-owned\n"
        "          access: read_write\n"
        f"        - mount: {mount['name']}\n"
        "          source: /\n"
        "          container: /usr/share/nginx/html\n"
        "          access: read_only\n"
        "      secrets:\n"
        "        - secret: secrets.acceptance_token\n"
        "          env: ACCEPTANCE_TOKEN_FILE\n"
        "    - name: postgres\n"
        "      image: docker.io/library/postgres:16\n"
        "      secrets:\n"
        "        - secret: secrets.acceptance_token\n"
        "          env: POSTGRES_PASSWORD_FILE\n"
        "      volumes:\n"
        "        - service_path: postgres\n"
        "          container: /var/lib/postgresql/data\n"
        "          access: read_write\n"
        "    - name: redis\n"
        "      image: docker.io/library/redis:7\n"
    )


def write_native_service_yaml(path, intent):
    primary = next(vm for vm in intent["vms"] if vm["role"] == "primary")
    path.write_text(
        f"name: {NATIVE_SERVICE_NAME}\n"
        "generated: true\n"
        "generated_by: service-layer-acceptance\n"
        "backend:\n"
        f"  vm: {primary['name']}\n"
        "  port: 18080\n"
        "ingress:\n"
        "  enabled: false\n"
        "deploy:\n"
        "  type: native\n"
        "  package: caddy\n"
        "  apt_repo: caddy_official\n"
        f"  service_name: {NATIVE_SERVICE_UNIT}\n"
        "  config_files:\n"
        "    - template: Caddyfile.j2\n"
        "      dest: /etc/caddy/Caddyfile\n"
        "      mode: \"0644\"\n"
        "      reload_on_change: true\n"
    )


def write_service_sops(repo_root, path):
    secret = service_secret_value(repo_root)
    path.write_text(
        "secrets:\n"
        "  acceptance_token:\n"
        "    created: 2026-05-12T00:00:00Z\n"
        "    version: 1\n"
        f"    value: {secret}\n"
    )


def service_secret_value(repo_root):
    return os.environ.get("FORTRESS_SERVICE_LAYER_SECRET", "generated-service-layer-acceptance-token")


def encrypt_service_sops(repo_root):
    return run(["sops", "--encrypt", "--in-place", str(repo_root / "inventory" / "services" / f"{SERVICE_NAME}.sops.yaml")])


def write_service_quadlet_fragment(path):
    path.mkdir()
    (path / "web.container").write_text(
        "[Container]\n"
        "Notify=false\n"
        "\n"
        "[Service]\n"
        "RestartSec=5\n"
    )


def write_native_service_templates(path):
    path.mkdir()
    (path / "Caddyfile.j2").write_text(
        ":18080 {\n"
        f"\trespond \"{NATIVE_SERVICE_MARKER}\"\n"
        "}\n"
    )


def run_service_deploy(repo_root, intent):
    return run([str(repo_root / "scripts" / "service-deploy"), SERVICE_NAME])


def run_native_service_deploy(repo_root, intent):
    return run([str(repo_root / "scripts" / "service-deploy"), NATIVE_SERVICE_NAME])


def reload_truenas_nfs_service(repo_root, intent):
    endpoint_name = intent["endpoint"]
    endpoint_sops = repo_root / "inventory" / "nas" / f"{endpoint_name}.sops.yaml"
    if not endpoint_sops.is_file():
        return subprocess.CompletedProcess(
            [],
            1,
            "",
            f"NAS Endpoint Sibling SOPS File is required at {endpoint_sops}",
        )
    try:
        credential = sops_extract_acceptance_credential(endpoint_sops)
    except subprocess.CalledProcessError as error:
        return subprocess.CompletedProcess(
            [],
            1,
            error.stdout or "",
            f"failed to decrypt Acceptance NAS Credential for NAS Endpoint {endpoint_name} from {endpoint_sops}",
        )
    if not credential:
        return subprocess.CompletedProcess(
            [],
            1,
            "",
            f"missing api_credentials.acceptance.value in NAS Endpoint Sibling SOPS File for NAS Endpoint {endpoint_name}: {endpoint_sops}",
        )

    fake_reload_log = os.environ.get("FORTRESS_FAKE_TRUENAS_RELOAD_LOG")
    endpoint = intent["endpoint_config"]
    tls_verify = endpoint.get("tls_verify", True)
    if fake_reload_log:
        with Path(fake_reload_log).open("a") as handle:
            handle.write(
                f"truenas reload_nfs_service {endpoint_name} "
                f"{endpoint['management_address']} {str(tls_verify).lower()} {credential}\n"
            )
        if os.environ.get("FORTRESS_FAKE_TRUENAS_RELOAD_FAIL"):
            return subprocess.CompletedProcess([], 42, "", "fake TrueNAS NFS service reload failure")
        return subprocess.CompletedProcess([], 0, "", "")

    child_env = os.environ.copy()
    child_env[RELOAD_CREDENTIAL_ENV] = credential
    pythonpath = child_env.get("PYTHONPATH")
    child_env["PYTHONPATH"] = str(REPO_ROOT) if not pythonpath else f"{REPO_ROOT}{os.pathsep}{pythonpath}"
    return run(
        [
            live_truenas_python(),
            str(Path(__file__).resolve()),
            "__reload-truenas-nfs-service",
            endpoint_name,
            endpoint["management_address"],
            "true" if tls_verify else "false",
        ],
        env=child_env,
    )


def reload_truenas_nfs_service_child(argv):
    if len(argv) != 3:
        print("usage: __reload-truenas-nfs-service <endpoint> <management-address> <tls-verify>", file=sys.stderr)
        return 2
    endpoint_name, management_address, tls_verify_text = argv
    credential = os.environ.get(RELOAD_CREDENTIAL_ENV)
    if not credential:
        print(f"missing {RELOAD_CREDENTIAL_ENV} for NAS Endpoint {endpoint_name}", file=sys.stderr)
        return 1
    try:
        from fortress_nas.truenas_client import LiveTrueNasClient, TrueNasCapabilityError

        with LiveTrueNasClient.connect(
            management_address,
            credential,
            tls_verify=tls_verify_text == "true",
        ) as client:
            client.reload_nfs_service()
    except TrueNasCapabilityError as error:
        print(error, file=sys.stderr)
        return 1
    return 0


def live_truenas_python():
    override = os.environ.get("FORTRESS_PYTHON")
    if override:
        return override
    if FORTRESS_RUNTIME_PYTHON.is_file():
        return str(FORTRESS_RUNTIME_PYTHON)
    return sys.executable


def sops_extract_acceptance_credential(endpoint_sops):
    return run(
        [
            "sops",
            "--decrypt",
            "--extract",
            '["api_credentials"]["acceptance"]["value"]',
            str(endpoint_sops),
        ]
    ).stdout.strip()


def verify_service_layer(repo_root, intent):
    mount_point = intent["policy"]["mount"]["mount_point"]
    checks = []
    primary, peer = intent["vms"]
    marker = os.environ.get("FORTRESS_SERVICE_LAYER_MARKER", f"fortress-service-layer-{int(time.time())}")
    marker_file = f"{mount_point}/index.html"
    expected_secret_hash = hashlib.sha256(service_secret_value(repo_root).encode()).hexdigest()
    service_units = [
        f"fortress-{SERVICE_NAME}-postgres.service",
        f"fortress-{SERVICE_NAME}-redis.service",
        f"fortress-{SERVICE_NAME}-web.service",
    ]
    checks.extend(
        [
            {"description": "checking Primary Acceptance VM mount unit", **LIFECYCLE.mount_health_checks(intent)[0]},
            {"description": "checking Primary Acceptance VM NFS mount", **LIFECYCLE.mount_health_checks(intent)[1]},
            {"description": "writing marker through Share-backed Volume", **ssh_check(primary, ["sh", "-lc", f"printf {shlex.quote(marker)} > {shlex.quote(marker_file)}"])},
            *[
                {"description": f"checking Service unit {service_unit}", **ssh_check(primary, ["systemctl", "is-active", service_unit])}
                for service_unit in service_units
            ],
            {"description": "checking postgres Container Alias from web container", **ssh_check(primary, ["podman", "exec", f"fortress-{SERVICE_NAME}-web", "getent", "hosts", "postgres"])},
            {"description": "checking redis Container Alias from web container", **ssh_check(primary, ["podman", "exec", f"fortress-{SERVICE_NAME}-web", "getent", "hosts", "redis"])},
            {
                "description": "checking Service Secret bytes inside web container",
                **ssh_check(
                    primary,
                    [
                    "podman",
                    "exec",
                    f"fortress-{SERVICE_NAME}-web",
                    "sh",
                    "-lc",
                    "sha256sum \"$ACCEPTANCE_TOKEN_FILE\" | awk '{print $1}'",
                    ],
                    expected_secret_hash,
                ),
            },
            {"description": "checking peer-to-primary Published Port reachability", **ssh_check(peer, ["curl", "-fsS", f"http://{primary['client']}:8080/"], marker)},
            {"description": "checking Native Service systemd unit caddy", **ssh_check(primary, ["systemctl", "is-active", NATIVE_SERVICE_UNIT])},
            {"description": "checking peer-to-primary Native Service reachability", **ssh_check(peer, ["curl", "-fsS", f"http://{primary['client']}:18080/"], NATIVE_SERVICE_MARKER)},
        ]
    )
    return LIFECYCLE.verify_named_checks(repo_root, checks, progress)


def verify_post_reload_data_flow(repo_root, intent):
    hostvars = LIFECYCLE.load_verification_hostvars(repo_root)
    mount_point = intent["policy"]["mount"]["mount_point"]
    primary, peer = intent["vms"]
    marker = os.environ.get("FORTRESS_SERVICE_LAYER_POST_RELOAD_MARKER", "post-reload-service-layer-marker")
    service_content = os.environ.get("FORTRESS_SERVICE_LAYER_POST_RELOAD_CONTENT", "post-reload-service-layer-content")
    marker_file = f"{mount_point}/post-reload-marker.txt"
    index_file = f"{mount_point}/index.html"
    marker_written = False
    checks = [
        {
            "description": "writing fresh post-reload marker through Primary Acceptance VM Mount",
            "creates_marker": True,
            **ssh_check(primary, ["sh", "-lc", f"printf {shlex.quote(marker)} > {shlex.quote(marker_file)}"]),
        },
        {
            "description": "reading fresh post-reload marker through Peer Acceptance VM Mount",
            "creates_marker": False,
            **ssh_check(peer, ["cat", marker_file], marker),
        },
        {
            "description": "updating Service-served index.html through Primary Acceptance VM Mount",
            "creates_marker": False,
            **ssh_check(primary, ["sh", "-lc", f"printf {shlex.quote(service_content)} > {shlex.quote(index_file)}"]),
        },
        {
            "description": "checking already-running Service serves fresh post-reload content",
            "creates_marker": False,
            **ssh_check(peer, ["curl", "-fsS", f"http://{primary['client']}:8080/"], service_content),
        },
    ]
    for check in checks:
        progress(check["description"])
        result = LIFECYCLE.verify_check(repo_root, hostvars, check)
        if result.returncode != 0:
            if marker_written:
                cleanup_post_reload_marker(repo_root, primary, hostvars, marker_file)
            return result
        marker_written = marker_written or check["creates_marker"]
    return cleanup_post_reload_marker(repo_root, primary, hostvars, marker_file)


def cleanup_post_reload_marker(repo_root, primary, hostvars, marker_file):
    progress("removing fresh post-reload marker from Primary Acceptance VM Mount")
    return LIFECYCLE.verify_check(repo_root, hostvars, ssh_check(primary, ["rm", "-f", marker_file]))


def failed_after_generation(repo_root, intent, phase, result, keep_on_fail, generated, provisioned, require_nas_cleanup=True):
    message = f"{phase} failed: {phase_detail(result)}"
    if keep_on_fail:
        print(f"{message}; preserved Service-layer acceptance resources for inspection", file=sys.stderr)
        return 1
    if generated:
        progress("cleaning up generated Acceptance resources after failure")
        cleanup = cleanup_resources(repo_root, intent, provisioned, require_nas_cleanup=require_nas_cleanup)
        if cleanup.returncode != 0:
            print(f"{message}; cleanup also failed: {phase_detail(cleanup)}", file=sys.stderr)
            return 1
    print(message, file=sys.stderr)
    return 1


def cleanup_resources(repo_root, intent, provisioned=None, require_nas_cleanup=True):
    stderr = []
    delete_registered_service_artifacts(repo_root, stderr)
    cleanup = LIFECYCLE.cleanup_resources(repo_root, intent, provisioned, require_nas_cleanup=require_nas_cleanup)
    if cleanup.returncode != 0:
        stderr.append(phase_detail(cleanup))
    if stderr:
        return subprocess.CompletedProcess([], 1, "", "; ".join(stderr))
    return subprocess.CompletedProcess([], 0, "", "")


def delete_registered_service_artifacts(repo_root, stderr):
    artifacts = [artifact for artifact in LIFECYCLE.discover_generated_artifacts(repo_root) if artifact.registered]
    plan = build_generated_artifact_cleanup_plan(artifacts)
    refused = [item["artifact"].path for item in plan if item["action"] == "refuse"]
    if refused:
        stderr.extend(f"refusing to delete non-generated Service-layer Acceptance artifact {path}" for path in refused)
        return
    stderr.extend(delete_generated_artifact_cleanup_plan(plan))


if __name__ == "__main__":
    raise SystemExit(main())
