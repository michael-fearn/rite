#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat >&2 <<'USAGE'
Usage: scripts/decrypt-keys <entity.sops.yaml>... -- <command> [args...]

Decrypts SSH private keys from sibling SOPS files into /dev/shm/fortress,
runs the command with FORTRESS_KEY_DIR set, then removes the plaintext keys.
USAGE
}

tmpfs_dir="${FORTRESS_KEY_DIR:-/dev/shm/fortress}"
declare -a sops_files=()
declare -a key_paths=()

cleanup() {
  if [[ ${#key_paths[@]} -gt 0 ]]; then
    rm -f -- "${key_paths[@]}"
  fi
  rmdir "$tmpfs_dir" 2>/dev/null || true
}
trap cleanup EXIT

while [[ $# -gt 0 ]]; do
  case "$1" in
    --)
      shift
      break
      ;;
    *.sops.yaml)
      sops_files+=("$1")
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "unexpected argument before --: $1" >&2
      usage
      exit 2
      ;;
  esac
done

if [[ ${#sops_files[@]} -eq 0 || $# -eq 0 ]]; then
  usage
  exit 2
fi

install -d -m 0700 "$tmpfs_dir"

for sops_file in "${sops_files[@]}"; do
  entity="$(basename "$sops_file" .sops.yaml)"
  key_path="$tmpfs_dir/${entity}.key"
  key_paths+=("$key_path")
  sops --decrypt --extract '["ssh_keys"]["bootstrap"]["private_key"]' "$sops_file" > "$key_path"
  chmod 0600 "$key_path"
done

FORTRESS_KEY_DIR="$tmpfs_dir" "$@"
