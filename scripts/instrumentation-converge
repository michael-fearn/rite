#!/usr/bin/env python3
import os
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from fortress_workflows import OperatorWorkflowRunner
from fortress_workflows.instrumentation_convergence import (
    build_instrumentation_convergence_plan,
    render_instrumentation_convergence_result,
)


def main():
    if sys.argv[1:]:
        print("usage: scripts/instrumentation-converge", file=sys.stderr)
        return 2

    repo_root = Path(os.environ.get("FORTRESS_ROOT", Path(__file__).resolve().parents[1]))
    try:
        plan = build_instrumentation_convergence_plan(repo_root)
    except ValueError as error:
        print(error, file=sys.stderr)
        return 1

    result = OperatorWorkflowRunner(cwd=repo_root).run(plan)
    render_instrumentation_convergence_result(plan, result)
    return result.return_code


if __name__ == "__main__":
    raise SystemExit(main())
