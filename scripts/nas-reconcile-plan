#!/usr/bin/env python3
import argparse
from contextlib import contextmanager
import json
import os
import re
import subprocess
import sys
from pathlib import Path

REPO_ROOT = Path(__file__).resolve().parents[1]
FORTRESS_RUNTIME_PYTHON = Path("/opt/fortress-python/bin/python3")
LIVE_APPLY_RUNTIME_REEXEC_ENV = "FORTRESS_NAS_RECONCILE_LIVE_APPLY_RUNTIME_REEXEC"
sys.path.insert(0, str(REPO_ROOT))

from fortress_inventory.model import load_inventory_tree
from fortress_nas.reconcile import (
    NasApplyError,
    RecordingNasClient,
    build_nas_reconcile_plan,
    destroy_ephemeral_postcondition_findings,
    load_reality,
)
from fortress_nas.truenas_client import LiveTrueNasClient, TrueNasCapabilityError


SOPS_EXTRACT_RECONCILE_CREDENTIAL = '["api_credentials"]["reconcile"]["value"]'
SOPS_EXTRACT_ACCEPTANCE_CREDENTIAL = '["api_credentials"]["acceptance"]["value"]'


class ReconcileCommandError(Exception):
    pass


def main():
    parser = argparse.ArgumentParser(prog="scripts/nas-reconcile-plan")
    mode = parser.add_mutually_exclusive_group(required=True)
    mode.add_argument("--reality-json", help="read-only TrueNAS reality fixture")
    mode.add_argument("--live", metavar="ENDPOINT", help="load reality from the named NAS Endpoint")
    parser.add_argument("--apply", action="store_true", help="apply fortress-owned Share changes")
    parser.add_argument(
        "--confirm-disruptive-mount-changes",
        action="store_true",
        help="continue when Mount removal, access changes, or mount_point changes are detected",
    )
    parser.add_argument(
        "--acceptance-ephemeral-datasets",
        action="store_true",
        help="allow Acceptance Test Ephemeral Dataset create/destroy operations",
    )
    parser.add_argument(
        "--destroy-ephemeral-datasets",
        action="store_true",
        help="destroy marked Acceptance Test Ephemeral Datasets instead of creating missing ones",
    )
    args = parser.parse_args()
    reexec_result = _reexec_live_apply_with_selected_runtime(args)
    if reexec_result is not None:
        return reexec_result

    repo_root = Path(os.environ.get("FORTRESS_ROOT", REPO_ROOT))
    live_context = None
    try:
        inventory = load_inventory_tree(repo_root)
        if args.reality_json:
            with Path(args.reality_json).open() as handle:
                reality = load_reality(json.load(handle))
        else:
            live_context = _load_live_reality(repo_root, inventory, args)
            reality = live_context["reality"]
    except ReconcileCommandError as error:
        print(error, file=sys.stderr)
        return 1

    try:
        with _apply_client(args, live_context) as client:
            plan = build_nas_reconcile_plan(
                inventory,
                reality,
                apply=args.apply,
                client=client,
                confirm_disruptive_mount_changes=args.confirm_disruptive_mount_changes,
                acceptance_ephemeral_datasets=args.acceptance_ephemeral_datasets,
                destroy_ephemeral_datasets=args.destroy_ephemeral_datasets,
            )
    except NasApplyError as error:
        print(error, file=sys.stderr)
        return 1
    except ReconcileCommandError as error:
        print(error, file=sys.stderr)
        return 1
    if (
        args.live
        and args.apply
        and args.acceptance_ephemeral_datasets
        and args.destroy_ephemeral_datasets
        and not plan["blocked"]
    ):
        try:
            refreshed_reality = _load_live_reality(repo_root, inventory, args, refreshed=True)["reality"]
        except ReconcileCommandError as error:
            print(error, file=sys.stderr)
            return 1
        plan["destroy_postcondition_findings"] = destroy_ephemeral_postcondition_findings(
            inventory,
            refreshed_reality,
        )
        plan["blocked"] = bool(plan["destroy_postcondition_findings"])
    if args.live:
        plan["connection"][args.live]["credentials"] = "operator_environment"
        plan["connection"][args.live]["credential_source"] = (
            f"inventory/nas/{args.live}.sops.yaml:{live_context['credential_path']}"
        )
    json.dump(plan, sys.stdout, indent=2, sort_keys=True)
    sys.stdout.write("\n")
    return 1 if plan["blocked"] else 0


def _load_live_reality(repo_root, inventory, args, refreshed=False):
    endpoint_name = args.live
    endpoint_yaml = repo_root / "inventory" / "nas" / f"{endpoint_name}.yaml"
    if endpoint_name not in inventory.nas_endpoints or not endpoint_yaml.is_file():
        raise ReconcileCommandError(
            f"NAS Endpoint {endpoint_name} is not declared in Inventory at {endpoint_yaml}"
        )
    endpoint_sops = repo_root / "inventory" / "nas" / f"{endpoint_name}.sops.yaml"
    if not endpoint_sops.is_file():
        raise ReconcileCommandError(
            f"NAS Endpoint Sibling SOPS File is required at {endpoint_sops}"
        )
    endpoint = inventory.nas_endpoints[endpoint_name]
    credential_path = (
        "api_credentials.acceptance.value"
        if args.acceptance_ephemeral_datasets
        else "api_credentials.reconcile.value"
    )
    credential_extract = (
        SOPS_EXTRACT_ACCEPTANCE_CREDENTIAL
        if args.acceptance_ephemeral_datasets
        else SOPS_EXTRACT_RECONCILE_CREDENTIAL
    )
    credential_label = "Acceptance NAS Credential" if args.acceptance_ephemeral_datasets else "NAS Reconcile Credential"
    try:
        credential = _sops_extract(endpoint_sops, credential_extract)
    except subprocess.CalledProcessError as error:
        raise ReconcileCommandError(
            f"failed to decrypt {credential_label} for NAS Endpoint {endpoint_name} "
            f"from {endpoint_sops}"
        ) from error
    if not credential:
        raise ReconcileCommandError(
            f"missing {credential_path} in NAS Endpoint Sibling SOPS File "
            f"for NAS Endpoint {endpoint_name}: {endpoint_sops}"
        )

    child_env = os.environ.copy()
    if refreshed:
        child_env["FORTRESS_TRUENAS_REALITY_REFRESH"] = "1"
    api_token_env = _credential_env_name(endpoint_name, acceptance=args.acceptance_ephemeral_datasets)
    child_env[api_token_env] = credential
    pythonpath = child_env.get("PYTHONPATH")
    child_env["PYTHONPATH"] = str(REPO_ROOT) if not pythonpath else f"{REPO_ROOT}{os.pathsep}{pythonpath}"
    result = subprocess.run(
        [
            _live_reality_python(),
            "-m",
            "fortress_nas.truenas_reality",
            endpoint_name,
            endpoint["management_address"],
            api_token_env,
            "true" if endpoint.get("tls_verify", True) else "false",
        ],
        cwd=repo_root,
        env=child_env,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    )
    if result.returncode != 0:
        detail = _safe_child_error(result.stderr, credential)
        suffix = f": {detail}" if detail else ""
        raise ReconcileCommandError(
            f"failed to load live TrueNAS reality for NAS Endpoint {endpoint_name}{suffix}"
        )
    try:
        return {
            "endpoint_name": endpoint_name,
            "management_address": endpoint["management_address"],
            "credential": credential,
            "credential_path": credential_path,
            "tls_verify": endpoint.get("tls_verify", True),
            "reality": load_reality(json.loads(result.stdout)),
        }
    except json.JSONDecodeError as error:
        raise ReconcileCommandError(
            f"live TrueNAS reality loader returned invalid JSON for NAS Endpoint {endpoint_name}"
        ) from error


@contextmanager
def _apply_client(args, live_context):
    if not args.apply:
        yield None
        return
    if not args.live:
        yield RecordingNasClient()
        return
    fake_apply_log = os.environ.get("FORTRESS_FAKE_TRUENAS_APPLY_LOG")
    if fake_apply_log:
        yield _FakeLiveTrueNasApplyClient(fake_apply_log)
        return
    try:
        with LiveTrueNasClient.connect(
            live_context["management_address"],
            live_context["credential"],
            tls_verify=live_context.get("tls_verify", True),
        ) as client:
            yield client
    except TrueNasCapabilityError as error:
        raise ReconcileCommandError(
            f"failed to apply live TrueNAS changes for NAS Endpoint "
            f"{live_context['endpoint_name']}: {error}"
        ) from error


class _FakeLiveTrueNasApplyClient:
    def __init__(self, log_path):
        self._log_path = Path(log_path)

    def create_dataset(self, dataset):
        self._fail_if_requested("create_dataset", dataset["name"])
        self._append({"method": "create_dataset", "dataset": dataset})

    def delete_dataset(self, dataset, path):
        self._fail_if_requested("delete_dataset", dataset)
        self._append({"method": "delete_dataset", "dataset": dataset, "path": path})

    def create_nfs_share(self, share):
        self._fail_if_requested("create_nfs_share", share["name"])
        self._append({"method": "create_nfs_share", "share": share})

    def update_nfs_share(self, share, desired):
        self._fail_if_requested("update_nfs_share", share)
        self._append({"method": "update_nfs_share", "share": share, "desired": desired})

    def delete_nfs_share(self, share):
        self._fail_if_requested("delete_nfs_share", share)
        self._append({"method": "delete_nfs_share", "share": share})

    def reload_nfs_service(self):
        self._fail_if_requested("reload_nfs_service", "nfs")
        self._append({"method": "reload_nfs_service"})

    def _fail_if_requested(self, method, target):
        if os.environ.get("FORTRESS_FAKE_TRUENAS_FAIL_METHOD") == method:
            raise RuntimeError(f"fake TrueNAS write failure for {method} {target}")

    def _append(self, operation):
        with self._log_path.open("a") as handle:
            handle.write(json.dumps(operation, sort_keys=True))
            handle.write("\n")


def _sops_extract(sops_file, extract):
    return subprocess.run(
        ["sops", "--decrypt", "--extract", extract, str(sops_file)],
        check=True,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    ).stdout.strip()


def _reexec_live_apply_with_selected_runtime(args):
    if not args.live or not args.apply:
        return None
    if os.environ.get(LIVE_APPLY_RUNTIME_REEXEC_ENV):
        return None
    selected_python = _live_reality_python()
    if Path(selected_python).absolute() == Path(sys.executable).absolute():
        return None
    child_env = os.environ.copy()
    child_env[LIVE_APPLY_RUNTIME_REEXEC_ENV] = "1"
    pythonpath = child_env.get("PYTHONPATH")
    child_env["PYTHONPATH"] = str(REPO_ROOT) if not pythonpath else f"{REPO_ROOT}{os.pathsep}{pythonpath}"
    result = subprocess.run(
        [selected_python, str(Path(__file__).resolve()), *sys.argv[1:]],
        env=child_env,
        text=True,
    )
    return result.returncode


def _live_reality_python():
    override = os.environ.get("FORTRESS_PYTHON")
    if override:
        return override
    if FORTRESS_RUNTIME_PYTHON.is_file():
        return str(FORTRESS_RUNTIME_PYTHON)
    return sys.executable


def _reconcile_credential_env_name(endpoint_name):
    return _credential_env_name(endpoint_name, acceptance=False)


def _credential_env_name(endpoint_name, acceptance=False):
    normalized = re.sub(r"[^A-Z0-9]+", "_", endpoint_name.upper()).strip("_")
    purpose = "ACCEPTANCE" if acceptance else "RECONCILE"
    return f"FORTRESS_NAS_{purpose}_{normalized}_TOKEN"


def _safe_child_error(stderr, credential):
    lines = [line.strip() for line in stderr.splitlines() if line.strip()]
    if not lines:
        return ""
    detail = lines[-1]
    if credential:
        detail = detail.replace(credential, "[redacted]")
        username, separator, key = credential.partition(":")
        if separator:
            detail = detail.replace(key, "[redacted]")
    return detail


if __name__ == "__main__":
    raise SystemExit(main())
