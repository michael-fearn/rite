#!/usr/bin/env python3
import json
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from fortress_inventory.model import load_inventory_tree
from fortress_tofu.generate import hcl_identifier


SOPS_EXTRACT_USER = '["pve_tokens"]["tofu"]["user"]'
SOPS_EXTRACT_TOKEN_ID = '["pve_tokens"]["tofu"]["token_id"]'
SOPS_EXTRACT_VALUE = '["pve_tokens"]["tofu"]["value"]'
SOPS_EXTRACT_SSH_PRIVATE_KEY = '["ssh_keys"]["bootstrap"]["private_key"]'


def main(argv=None):
    argv = list(sys.argv[1:] if argv is None else argv)
    if not argv:
        print("usage: scripts/tofu-wrap <tofu-args...>", file=sys.stderr)
        return 2

    repo_root = Path(os.environ.get("FORTRESS_ROOT", Path(__file__).resolve().parents[1]))
    tofu_root = repo_root / "tofu"
    try:
        selected_vm = _selected_vm_arg(argv)
        provider_hosts = _provider_hosts(repo_root, selected_vm)
        token_env = _host_secret_env(repo_root, selected_vm, provider_hosts=provider_hosts)
        generate_command = [str(_script_root() / "tofu-generate"), str(repo_root)]
        if selected_vm:
            generate_command.extend(["--selected-vm", selected_vm])
            for host in sorted(provider_hosts):
                generate_command.extend(["--provider-host", host])
        subprocess.run(generate_command, check=True)
        env = os.environ.copy()
        env.update(token_env)
        env["HOME"] = str(_tofu_home())
        return subprocess.run(["tofu", *argv], cwd=tofu_root, env=env).returncode
    except WrapperError as error:
        print(error, file=sys.stderr)
        return 1
    except subprocess.CalledProcessError as error:
        return error.returncode or 1


class WrapperError(Exception):
    pass


def _host_secret_env(repo_root, selected_vm=None, provider_hosts=None):
    model = load_inventory_tree(repo_root)
    hosts = model.hosts
    if selected_vm:
        if selected_vm not in model.vms:
            raise WrapperError(f"selected VM {selected_vm!r} is not declared in Inventory")
        host = model.vms[selected_vm].get("placement", {}).get("host")
        selected_hosts = {host, *(provider_hosts or [])}
        hosts = {selected_host: model.hosts[selected_host] for selected_host in selected_hosts if selected_host in model.hosts}
    env = {}
    for host in sorted(hosts):
        host_sops = repo_root / "inventory" / "hosts" / f"{host}.sops.yaml"
        if not host_sops.is_file():
            raise WrapperError(f"missing Host Sibling SOPS File for Host {host}: {host_sops}")
        token = _decrypt_tofu_token(host, host_sops)
        if not token:
            raise WrapperError(f"missing pve_tokens.tofu.value in Host Sibling SOPS File for Host {host}: {host_sops}")
        env[f"TF_VAR_pve_token_{hcl_identifier(host)}"] = token
        ssh_private_key = _decrypt_host_ssh_private_key(host, host_sops)
        env[f"TF_VAR_pve_ssh_private_key_{hcl_identifier(host)}"] = ssh_private_key
    return env


def _selected_vm_arg(argv):
    for index, arg in enumerate(argv):
        if arg == "-var" and index + 1 < len(argv):
            name, _, value = argv[index + 1].partition("=")
            if name == "selected_vm":
                return value
        if arg.startswith("-var="):
            name, _, value = arg.removeprefix("-var=").partition("=")
            if name == "selected_vm":
                return value
    return None


def _provider_hosts(repo_root, selected_vm=None):
    if not selected_vm:
        return set()
    state_hosts = _state_provider_hosts(repo_root)
    model = load_inventory_tree(repo_root)
    selected_host = model.vms.get(selected_vm, {}).get("placement", {}).get("host")
    if selected_host:
        state_hosts.add(selected_host)
    return state_hosts


def _state_provider_hosts(repo_root):
    state_file = repo_root / "tofu" / "terraform.tfstate"
    if not state_file.is_file():
        return set()
    try:
        state = json.loads(state_file.read_text())
    except (OSError, json.JSONDecodeError) as error:
        raise WrapperError(f"failed to read OpenTofu state providers from {state_file}: {error}") from error
    alias_to_host = {
        hcl_identifier(host): host
        for host in load_inventory_tree(repo_root).hosts
    }
    hosts = set()
    for resource in state.get("resources", []) or []:
        provider = resource.get("provider", "")
        marker = 'provider["registry.opentofu.org/bpg/proxmox"].'
        if marker not in provider:
            continue
        alias = provider.rsplit(".", 1)[-1]
        host = alias_to_host.get(alias)
        if not host:
            raise WrapperError(f"OpenTofu state references unknown Proxmox provider alias {alias!r}")
        hosts.add(host)
    return hosts


def _script_root():
    return Path(__file__).resolve().parent


def _tofu_home():
    home = Path("/dev/shm/fortress/tofu-home")
    try:
        (home / ".ssh").mkdir(mode=0o700, parents=True, exist_ok=True)
        (home / ".ssh" / "known_hosts").touch(mode=0o600, exist_ok=True)
        return home
    except OSError:
        home = Path(os.environ.get("TMPDIR", "/tmp")) / "fortress-tofu-home"
        (home / ".ssh").mkdir(mode=0o700, parents=True, exist_ok=True)
        (home / ".ssh" / "known_hosts").touch(mode=0o600, exist_ok=True)
        return home


def _decrypt_tofu_token(host, host_sops):
    try:
        user = _sops_extract(host_sops, SOPS_EXTRACT_USER)
        token_id = _sops_extract(host_sops, SOPS_EXTRACT_TOKEN_ID)
        value = _sops_extract(host_sops, SOPS_EXTRACT_VALUE)
        if not value:
            return ""
        if "!" in value and "=" in value:
            return value
        return f"{user}!{token_id}={value}"
    except subprocess.CalledProcessError as error:
        raise WrapperError(
            f"failed to decrypt pve_tokens.tofu.value for Host {host} from {host_sops}"
        ) from error


def _decrypt_host_ssh_private_key(host, host_sops):
    try:
        return _sops_extract(host_sops, SOPS_EXTRACT_SSH_PRIVATE_KEY)
    except subprocess.CalledProcessError as error:
        raise WrapperError(f"failed to decrypt Host SSH private key for Host {host} from {host_sops}") from error


def _sops_extract(host_sops, extract):
    return subprocess.run(
        ["sops", "--decrypt", "--extract", extract, str(host_sops)],
        check=True,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
    ).stdout.strip()


if __name__ == "__main__":
    raise SystemExit(main())
