#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from fortress_inventory.model import load_inventory_tree
from fortress_tofu.generate import hcl_identifier


def main():
    if len(sys.argv) not in (2, 3):
        print("usage: scripts/vm-destroy <vm> [--delete-vm-yaml]", file=sys.stderr)
        return 2

    vm = sys.argv[1].removeprefix("vm=")
    delete_vm_yaml = False
    if len(sys.argv) == 3:
        if sys.argv[2] != "--delete-vm-yaml":
            print("usage: scripts/vm-destroy <vm> [--delete-vm-yaml]", file=sys.stderr)
            return 2
        delete_vm_yaml = True

    repo_root = Path(os.environ.get("FORTRESS_ROOT", Path(__file__).resolve().parents[1]))
    model = load_inventory_tree(repo_root)
    if vm not in model.vms:
        print(f"VM {vm!r} is not declared at {repo_root / 'inventory' / 'vms' / f'{vm}.yaml'}", file=sys.stderr)
        return 1

    references = service_backend_references(model.services, vm)
    if references:
        print(
            f"VM {vm} is still referenced by Service Backend(s): {', '.join(references)}",
            file=sys.stderr,
        )
        return 1

    host = model.vms[vm].get("placement", {}).get("host")
    target = f'module.vms_{hcl_identifier(host)}.proxmox_virtual_environment_vm.vm["{vm}"]'
    destroy_result = run_phase(
        "tofu destroy",
        [
            str(repo_root / "scripts" / "tofu-wrap"),
            "destroy",
            "-var",
            f"selected_vm={vm}",
            "-target",
            target,
            "-auto-approve",
        ],
        vm,
    )
    if destroy_result != 0:
        return destroy_result

    return delete_inventory_files(repo_root, vm, delete_vm_yaml)


def service_backend_references(services, vm):
    references = []
    for service_name, service in sorted(services.items()):
        backend = service.get("backend", {})
        if isinstance(backend, dict) and backend.get("vm") == vm:
            references.append(service_name)
    return references


def run_phase(phase, command, vm):
    try:
        result = subprocess.run(command)
    except OSError as error:
        print(f"{phase} failed for VM {vm}: {error}", file=sys.stderr)
        return 1
    if result.returncode != 0:
        print(f"{phase} failed for VM {vm}", file=sys.stderr)
        return result.returncode or 1
    return 0


def delete_inventory_files(repo_root, vm, delete_vm_yaml):
    vm_yaml = repo_root / "inventory" / "vms" / f"{vm}.yaml"
    vm_sops = repo_root / "inventory" / "vms" / f"{vm}.sops.yaml"

    if not delete_file(vm_sops, "VM Sibling SOPS File", missing_ok=True):
        return 1
    if delete_vm_yaml and not delete_file(vm_yaml, "VM yaml", missing_ok=False):
        return 1
    return 0


def delete_file(path, label, missing_ok):
    try:
        path.unlink()
    except FileNotFoundError:
        if missing_ok:
            print(f"{label} already absent: {path}")
            return True
        print(f"{label} is missing: {path}", file=sys.stderr)
        return False
    except OSError as error:
        print(f"failed to delete {label} at {path}: {error}", file=sys.stderr)
        return False
    print(f"Deleted {label}: {path}")
    return True


if __name__ == "__main__":
    raise SystemExit(main())
