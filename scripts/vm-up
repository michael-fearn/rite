#!/usr/bin/env python3
import os
import subprocess
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

from fortress_inventory.model import load_inventory_tree
from fortress_tofu.generate import hcl_identifier


def main():
    parsed = parse_args(sys.argv[1:])
    if parsed is None:
        print("usage: scripts/vm-up <vm> [--auto-confirm]", file=sys.stderr)
        return 2

    vm, auto_confirm = parsed
    repo_root = Path(os.environ.get("FORTRESS_ROOT", Path(__file__).resolve().parents[1]))
    vm_yaml = repo_root / "inventory" / "vms" / f"{vm}.yaml"
    if not vm_yaml.is_file():
        print(f"VM {vm!r} is not declared at {vm_yaml}", file=sys.stderr)
        return 1

    target_args = selected_vm_target_args(repo_root, vm)
    if target_args is None:
        return 1

    phases = [
        ("Prepare", [str(repo_root / "scripts" / "vm-prepare"), vm]),
        ("tofu plan", [str(repo_root / "scripts" / "tofu-wrap"), "plan", "-var", f"selected_vm={vm}", *target_args]),
    ]
    for phase, command in phases:
        returncode = run_phase(phase, command, vm)
        if returncode != 0:
            return returncode

    if not auto_confirm:
        approval = input(f"Type 'apply {vm}' to apply the selected-VM plan: ")
        if approval != f"apply {vm}":
            print(f"Apply denied for VM {vm}", file=sys.stderr)
            return 1

    phases = [
        (
            "tofu apply",
            [str(repo_root / "scripts" / "tofu-wrap"), "apply", "-var", f"selected_vm={vm}", *target_args, "-auto-approve"],
        ),
        ("Configure", [str(repo_root / "scripts" / "vm-configure"), vm]),
    ]
    for phase, command in phases:
        returncode = run_phase(phase, command, vm)
        if returncode != 0:
            return returncode

    return 0


def parse_args(args):
    if not (1 <= len(args) <= 2):
        return None

    vm = args[0].removeprefix("vm=")
    auto_confirm = False
    if len(args) == 2:
        if args[1] != "--auto-confirm":
            return None
        auto_confirm = True

    return vm, auto_confirm


def selected_vm_target_args(repo_root, vm):
    model = load_inventory_tree(repo_root)
    host = model.vms.get(vm, {}).get("placement", {}).get("host")
    if not host:
        print(f"VM {vm!r} has no placement.host", file=sys.stderr)
        return None
    host_alias = hcl_identifier(host)
    return [
        "-target",
        f'module.vms_{host_alias}.proxmox_virtual_environment_file.cloud_init_user_data["{vm}"]',
        "-target",
        f'module.vms_{host_alias}.proxmox_virtual_environment_vm.vm["{vm}"]',
    ]


def run_phase(phase, command, vm):
    try:
        result = subprocess.run(command)
    except OSError as error:
        print(f"{phase} failed for VM {vm}: {error}", file=sys.stderr)
        return 1
    if result.returncode != 0:
        print(f"{phase} failed for VM {vm}", file=sys.stderr)
        return result.returncode or 1
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
